<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <ResearchTabDef>
        <defName>MN_MatterNetworkTab</defName>
        <label>Matter Network</label>
    </ResearchTabDef>

    <ResearchProjectDef>
        <defName>MN_MatterNetwork</defName>
        <label>matter digitization</label>
        <description>By reducing physical matter to stable digital patterns, colonists can archive goods in banks of encoded storage and retrieve them when needed. What was once a logistical nightmare becomes a seamless web of matter, memory, and control.</description>
        <tab>MN_MatterNetworkTab</tab>
        <baseCost>6000</baseCost>
        <techLevel>Spacer</techLevel>
        <prerequisites>
            <li>AdvancedFabrication</li>
        </prerequisites>
        <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
        <requiredResearchFacilities>
            <li>MultiAnalyzer</li>
        </requiredResearchFacilities>
        <researchViewX>0.00</researchViewX>
        <researchViewY>0.50</researchViewY>
        <generalRules>
            <rulesStrings>
                <li>subject->matter-networking</li>
                <li>subject_story->digitized a colony's storage infrastructure</li>
                <li>subject_story->developed stable matter-to-data conversion</li>
                <li>subject_story->linked storage devices into a unified logistics network</li>
                <li>subject_gerund->constructing matter network infrastructure</li>
            </rulesStrings>
        </generalRules>
    </ResearchProjectDef>

    <ResearchProjectDef>
        <defName>MN_NetworkIO</defName>
        <label>matter network I/O</label>
        <description>Automated import and export ports let a matter network exchange items with adjacent stockpiles, shelves, and compatible storage devices without pawn labor.</description>
        <tab>MN_MatterNetworkTab</tab>
        <baseCost>2500</baseCost>
        <techLevel>Spacer</techLevel>
        <prerequisites>
            <li>MN_MatterNetwork</li>
        </prerequisites>
        <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
        <requiredResearchFacilities>
            <li>MultiAnalyzer</li>
        </requiredResearchFacilities>
        <researchViewX>1.00</researchViewX>
        <researchViewY>2.50</researchViewY>
        <generalRules>
            <rulesStrings>
                <li>subject->matter network I/O</li>
                <li>subject_story->automated matter network imports and exports</li>
                <li>subject_story->linked adjacent storage to digitized matter reserves</li>
                <li>subject_gerund->building matter network I/O ports</li>
            </rulesStrings>
        </generalRules>
    </ResearchProjectDef>

    <ResearchProjectDef>
        <defName>MN_NetworkPowerStorage</defName>
        <label>network power storage</label>
        <description>By adapting high-density capacitors for encoded matter networks, colonists can build reserve cells that keep network storage available during grid outages, solar flares, and temporary power shortages.</description>
        <tab>MN_MatterNetworkTab</tab>
        <baseCost>3000</baseCost>
        <techLevel>Spacer</techLevel>
        <prerequisites>
            <li>MN_MatterNetwork</li>
        </prerequisites>
        <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
        <requiredResearchFacilities>
            <li>MultiAnalyzer</li>
        </requiredResearchFacilities>
        <researchViewX>1.00</researchViewX>
        <researchViewY>0.50</researchViewY>
        <generalRules>
            <rulesStrings>
                <li>subject->network power storage</li>
                <li>subject_story->buffered a matter network against power failure</li>
                <li>subject_story->built reserve cells for digitized storage</li>
                <li>subject_gerund->building network reserve capacitors</li>
            </rulesStrings>
        </generalRules>
    </ResearchProjectDef>

    <ResearchProjectDef>
        <defName>MN_NetworkRefueling</defName>
        <label>fuel relays</label>
        <description>Automated matter routing lets connected relay nodes draw fuel from network storage and replenish nearby machines without pawn labor.</description>
        <tab>MN_MatterNetworkTab</tab>
        <baseCost>2500</baseCost>
        <techLevel>Spacer</techLevel>
        <prerequisites>
            <li>MN_MatterNetwork</li>
        </prerequisites>
        <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
        <requiredResearchFacilities>
            <li>MultiAnalyzer</li>
        </requiredResearchFacilities>
        <researchViewX>1.00</researchViewX>
        <researchViewY>1.50</researchViewY>
        <generalRules>
            <rulesStrings>
                <li>subject->fuel relays</li>
                <li>subject_story->automated colony fuel distribution</li>
                <li>subject_story->linked fuel storage to local relay nodes</li>
                <li>subject_gerund->building fuel relays</li>
            </rulesStrings>
        </generalRules>
    </ResearchProjectDef>
    
</Defs>
