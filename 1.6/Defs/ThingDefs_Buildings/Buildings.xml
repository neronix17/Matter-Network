<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <ThingDef ParentName="BuildingBase">
        <defName>MN_NetworkCable</defName>
        <label>network cable</label>
        <description>A bundle of network cables for moving data around. Can be placed under walls and other buildings.</description>
        <thingClass>SK_Matter_Network.NetworkBuilding</thingClass>
        <category>Building</category>
        <noRightClickDraftAttack>true</noRightClickDraftAttack>
        <comps>
            <li Class="SK_Matter_Network.CompProperties_NetworkBuilding">
                <powerUsage>0</powerUsage>
            </li>
        </comps>
        <graphicData>
            <texPath>Things/Building/Linked/PowerConduit_Atlas</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <linkType>Transmitter</linkType>
            <linkFlags>
                <li>PowerConduit</li>
            </linkFlags>
            <damageData>
                <rect>(0,0.35,1,0.3)</rect>
            </damageData>
            <color>(0,0,0,0)</color>
            <shaderType>Transparent</shaderType>
        </graphicData>
        <uiIconPath>Things/Building/Linked/PowerConduit_MenuIcon</uiIconPath>
        <uiIconScale>0.7</uiIconScale>
        <building>
            <isPowerConduit>false</isPowerConduit>
            <ai_chillDestination>false</ai_chillDestination>
            <isInert>true</isInert>
            <isEdifice>false</isEdifice>
            <canLandGravshipOn>true</canLandGravshipOn>
            <blueprintGraphicData>
                <texPath>Things/Building/Linked/PowerConduit_Blueprint_Atlas</texPath>
            </blueprintGraphicData>
            <canConstructInCorner>true</canConstructInCorner>
            <ai_neverTrashThis>true</ai_neverTrashThis>
            <isTargetable>false</isTargetable>
            <expandHomeArea>false</expandHomeArea>
            <canBeDamagedByAttacks>false</canBeDamagedByAttacks>
        </building>
        <drawerType>MapMeshOnly</drawerType>
        <altitudeLayer>Conduits</altitudeLayer>
        <passability>Standable</passability>
        <leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
        <resourcesFractionWhenDeconstructed>0</resourcesFractionWhenDeconstructed>
        <statBases>
            <MaxHitPoints>100</MaxHitPoints>
            <WorkToBuild>100</WorkToBuild>
            <Flammability>0</Flammability>
            <Beauty>-2</Beauty>
        </statBases>
        <drawStyleCategory>Conduits</drawStyleCategory>
        <costList>
            <Steel>4</Steel>
        </costList>
        <placeWorkers>
            <li>SK_Matter_Network.PlaceWorker_OneControllerPerNetwork</li>
        </placeWorkers>
        <rotatable>false</rotatable>
        <selectable>true</selectable>
        <neverMultiSelect>true</neverMultiSelect>
        <soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
        <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
        <researchPrerequisites>
            <li>MN_MatterNetwork</li>
        </researchPrerequisites>
        <designationCategory>Misc</designationCategory>
        <uiOrder>2000</uiOrder>
        <constructEffect>ConstructMetal</constructEffect>
        <clearBuildingArea>false</clearBuildingArea>
    </ThingDef>

    <ThingDef ParentName="BuildingBase">
        <defName>MN_DiskDrive</defName>
        <label>disk drive</label>
        <description>Holds matter disks that provide storage capacity to a connected data network. Can hold up to 6 disks. Add more drives or larger disks to increase how much the network can store.</description>
        <graphicData>
            <texPath>Things/Building/SpacerProps/ServerRack/ServerRack</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(1.5,1.5)</drawSize>
            <shaderType>CutoutComplex</shaderType>
            <shadowData>
                <volume>(0.55, 0.30, 0.40)</volume>
            </shadowData>
        </graphicData>
        <category>Building</category>
        <statBases>
            <MaxHitPoints>300</MaxHitPoints>
            <WorkToBuild>1000</WorkToBuild>
            <Flammability>0.5</Flammability>
            <Beauty>-1</Beauty>
        </statBases>
        <thingClass>SK_Matter_Network.NetworkBuildingDiskDrive</thingClass>
        <comps>
            <li Class="SK_Matter_Network.CompProperties_NetworkBuilding">
                <powerUsage>200</powerUsage>
            </li>
        </comps>
        <costList>
            <Steel>200</Steel>
            <ComponentIndustrial>2</ComponentIndustrial>
        </costList>
        <building>
            <storageGroupTag>DiskDrive</storageGroupTag>
            <fixedStorageSettings>
                <filter>
                    <thingDefs>
                        <li>MN_Disk1k</li>
                        <li>MN_Disk2k</li>
                        <li>MN_Disk4k</li>
                        <li>MN_Disk8k</li>
                        <li>MN_Disk16k</li>
                        <li>MN_Disk32k</li>
                    </thingDefs>
                </filter>
            </fixedStorageSettings>
            <defaultStorageSettings>
                <priority>Preferred</priority>
                <filter>
                    <thingDefs>
                        <li>MN_Disk1k</li>
                        <li>MN_Disk2k</li>
                        <li>MN_Disk4k</li>
                        <li>MN_Disk8k</li>
                        <li>MN_Disk16k</li>
                        <li>MN_Disk32k</li>
                    </thingDefs>
                </filter>
            </defaultStorageSettings>
            <preventDeteriorationOnTop>true</preventDeteriorationOnTop>
            <ignoreStoredThingsBeauty>true</ignoreStoredThingsBeauty>
            <maxItemsInCell>6</maxItemsInCell>
            <blueprintClass>Blueprint_Storage</blueprintClass>
            <destroySound>BuildingDestroyed_Metal_Small</destroySound>
        </building>
        <altitudeLayer>Building</altitudeLayer>
        <passability>PassThroughOnly</passability>
        <fillPercent>0.4</fillPercent>
        <pathCost>50</pathCost>
        <inspectorTabs>
            <li>ITab_Storage</li>
            <li>SK_Matter_Network.ITab_DiskDriveSlots</li>
        </inspectorTabs>
        <surfaceType>None</surfaceType>
        <canOverlapZones>false</canOverlapZones>
        <placeWorkers>
            <li>SK_Matter_Network.PlaceWorker_OneControllerPerNetwork</li>
        </placeWorkers>
        <researchPrerequisites>
            <li>MN_MatterNetwork</li>
        </researchPrerequisites>
        <uiOrder>2050</uiOrder>
        <designationCategory>Misc</designationCategory>
        <preventDroppingThingsOn>true</preventDroppingThingsOn>
        <defaultPlacingRot>South</defaultPlacingRot>
        <uiIconScale>0.8</uiIconScale>
    </ThingDef>

    <ThingDef ParentName="BuildingBase">
        <defName>MN_NetworkInterface</defName>
        <label>network interface</label>
        <description>A storage access point for a data network. Pawns can upload and extract allowed items here when the network has an active controller, and the selected storage filter is shared across the network.</description>
        <graphicData>
            <texPath>Things/Building/SpacerProps/SingleDisplay/SingleDisplay</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(1.2,1.2)</drawSize>
            <shaderType>CutoutComplex</shaderType>
            <shadowData>
                <volume>(0.3, 0.30, 0.40)</volume>
            </shadowData>
        </graphicData>
        <category>Building</category>
        <noRightClickDraftAttack>true</noRightClickDraftAttack>
        <statBases>
            <MaxHitPoints>200</MaxHitPoints>
            <WorkToBuild>500</WorkToBuild>
            <Mass>12</Mass>
            <StyleDominance MayRequire="Ludeon.RimWorld.Ideology">5</StyleDominance>
            <Flammability>0.5</Flammability>
            <Beauty>-1</Beauty>
        </statBases>
        <thingClass>SK_Matter_Network.NetworkBuildingNetworkInterface</thingClass>
        <comps>
            <li Class="SK_Matter_Network.CompProperties_NetworkBuilding">
                <powerUsage>400</powerUsage>
            </li>
        </comps>
        <costList>
            <Steel>400</Steel>
            <ComponentSpacer>2</ComponentSpacer>
            <Plasteel>50</Plasteel>
        </costList>
        <building>
            <fixedStorageSettings>
                <filter>
                    <categories>
                        <li>Root</li>
                    </categories>
                    <disallowedCategories>
                        <li>Animals</li>
                        <li>Plants</li>
                    </disallowedCategories>
                    <disallowedThingDefs>
                        <li>MN_Disk1k</li>
                        <li>MN_Disk2k</li>
                        <li>MN_Disk4k</li>
                        <li>MN_Disk8k</li>
                        <li>MN_Disk16k</li>
                        <li>MN_Disk32k</li>
                    </disallowedThingDefs>
                </filter>
            </fixedStorageSettings>
            <defaultStorageSettings>
                <priority>Preferred</priority>
                <filter>
                    <categories>
                        <li>Foods</li>
                        <li>Manufactured</li>
                        <li>ResourcesRaw</li>
                        <li>Items</li>
                        <li>Weapons</li>
                        <li>Apparel</li>
                        <li>BodyParts</li>
                    </categories>
                </filter>
            </defaultStorageSettings>
            <preventDeteriorationOnTop>true</preventDeteriorationOnTop>
            <ignoreStoredThingsBeauty>true</ignoreStoredThingsBeauty>
            <maxItemsInCell>500</maxItemsInCell>
            <blueprintClass>Blueprint_Storage</blueprintClass>
            <destroySound>BuildingDestroyed_Metal_Small</destroySound>
        </building>
        <altitudeLayer>Building</altitudeLayer>
        <minifiedDef>MinifiedThing</minifiedDef>
        <thingCategories>
            <li>BuildingsMisc</li>
        </thingCategories>
        <passability>PassThroughOnly</passability>
        <fillPercent>0.4</fillPercent>
        <pathCost>50</pathCost>
        <inspectorTabs>
            <li>ITab_Storage</li>
            <li>SK_Matter_Network.ITab_NetworkStorage</li>
        </inspectorTabs>
        <surfaceType>None</surfaceType>
        <canOverlapZones>false</canOverlapZones>
        <placeWorkers>
            <li>SK_Matter_Network.PlaceWorker_OneControllerPerNetwork</li>
        </placeWorkers>
        <researchPrerequisites>
            <li>MN_MatterNetwork</li>
        </researchPrerequisites>
        <uiOrder>2050</uiOrder>
        <designationCategory>Misc</designationCategory>
        <preventDroppingThingsOn>true</preventDroppingThingsOn>
        <hasInteractionCell>true</hasInteractionCell>
        <interactionCellOffset>(0,0,1)</interactionCellOffset>
        <defaultPlacingRot>South</defaultPlacingRot>
        <uiIconScale>0.8</uiIconScale>
    </ThingDef>

    <ThingDef ParentName="BuildingBase">
        <defName>MN_NetworkController</defName>
        <label>network controller</label>
        <description>The central hub of a data network. Stores all items digitally. A network can have only one active controller.</description>
        <thingClass>SK_Matter_Network.NetworkBuildingController</thingClass>
        <comps>
            <li Class="SK_Matter_Network.CompProperties_NetworkBuilding">
                <powerUsage>500</powerUsage>
            </li>
            <li Class="SK_Matter_Network.CompProperties_NetworkPowerController">
                <basePowerConsumption>500</basePowerConsumption>
                <updateIntervalTicks>60</updateIntervalTicks>
                <chargeEfficiency>1</chargeEfficiency>
                <chargingSurplusBufferWatts>50</chargingSurplusBufferWatts>
            </li>
            <li Class="CompProperties_Flickable"/>
            <li Class="CompProperties_Breakdownable"/>
        </comps>
        <graphicData>
            <texPath>Things/Building/SpacerProps/PersonalConsole/PersonalConsole</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(1.5,1.5)</drawSize>
            <shaderType>CutoutComplex</shaderType>
            <shadowData>
                <volume>(0.55, 0.30, 0.40)</volume>
            </shadowData>
        </graphicData>
        <altitudeLayer>Building</altitudeLayer>
        <minifiedDef>MinifiedThing</minifiedDef>
        <thingCategories>
            <li>BuildingsMisc</li>
        </thingCategories>
        <passability>PassThroughOnly</passability>
        <fillPercent>0.2</fillPercent>
        <statBases>
            <MaxHitPoints>400</MaxHitPoints>
            <WorkToBuild>2000</WorkToBuild>
            <Mass>18</Mass>
            <Flammability>0.5</Flammability>
        </statBases>
        <size>(1,1)</size>
        <costList>
            <Steel>500</Steel>
            <ComponentSpacer>4</ComponentSpacer>
            <Plasteel>50</Plasteel>
            <Gold>20</Gold>
        </costList>
        <building>
            <fixedStorageSettings>
                <filter>
                    <categories>
                        <li>Root</li>
                    </categories>
                    <disallowedThingDefs>
                        <li>MN_Disk1k</li>
                        <li>MN_Disk2k</li>
                        <li>MN_Disk4k</li>
                        <li>MN_Disk8k</li>
                        <li>MN_Disk16k</li>
                        <li>MN_Disk32k</li>
                    </disallowedThingDefs>
                </filter>
            </fixedStorageSettings>
            <destroySound>BuildingDestroyed_Metal_Small</destroySound>
        </building>
        <placeWorkers>
            <li>SK_Matter_Network.PlaceWorker_OneControllerPerNetwork</li>
        </placeWorkers>
        <inspectorTabs>
            <li>SK_Matter_Network.ITab_NetworkStorage</li>
        </inspectorTabs>
        <constructionSkillPrerequisite>8</constructionSkillPrerequisite>
        <researchPrerequisites>
            <li>MN_MatterNetwork</li>
        </researchPrerequisites>
        <designationCategory>Misc</designationCategory>
        <defaultPlacingRot>South</defaultPlacingRot>
        <uiIconScale>1</uiIconScale>
    </ThingDef>

    <ThingDef ParentName="BuildingBase">
        <defName>MN_MatterIOPort</defName>
        <label>matter IO port</label>
        <description>Automatically imports or exports items between a connected Matter Network and one adjacent storage target. Its filter controls which items may move, and its selected arrow shows the active side.</description>
        <thingClass>SK_Matter_Network.NetworkBuildingMatterIOPort</thingClass>
        <graphicData>
            <texPath>Things/Building/SpacerProps/SmallPlanningTable/SmallPlanningTable</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(1,1)</drawSize>
            <shaderType>CutoutComplex</shaderType>
        </graphicData>
        <castEdgeShadows>True</castEdgeShadows>
        <category>Building</category>
        <noRightClickDraftAttack>true</noRightClickDraftAttack>
        <statBases>
            <MaxHitPoints>180</MaxHitPoints>
            <WorkToBuild>750</WorkToBuild>
            <Mass>12</Mass>
            <Flammability>0.2</Flammability>
            <Beauty>-1</Beauty>
        </statBases>
        <size>(1,1)</size>
        <costList>
            <Steel>150</Steel>
            <ComponentIndustrial>2</ComponentIndustrial>
            <ComponentSpacer>1</ComponentSpacer>
            <Plasteel>20</Plasteel>
        </costList>
        <comps>
            <li Class="CompProperties_Forbiddable"/>
            <li Class="SK_Matter_Network.CompProperties_NetworkBuilding">
                <powerUsage>300</powerUsage>
            </li>
            <li Class="SK_Matter_Network.CompProperties_MatterIOPort">
                <defaultTickInterval>600</defaultTickInterval>
                <minTickInterval>60</minTickInterval>
                <maxTickInterval>6000</maxTickInterval>
                <maxInputStacksPerTick>1</maxInputStacksPerTick>
                <defaultMode>Input</defaultMode>
            </li>
        </comps>
        <building>
            <fixedStorageSettings>
                <filter>
                    <categories>
                        <li>Root</li>
                    </categories>
                    <disallowedCategories>
                        <li>Animals</li>
                        <li>Plants</li>
                    </disallowedCategories>
                    <disallowedThingDefs>
                        <li>MN_Disk1k</li>
                        <li>MN_Disk2k</li>
                        <li>MN_Disk4k</li>
                        <li>MN_Disk8k</li>
                        <li>MN_Disk16k</li>
                        <li>MN_Disk32k</li>
                    </disallowedThingDefs>
                </filter>
            </fixedStorageSettings>
            <defaultStorageSettings>
                <filter>
                    <categories>
                        <li>Foods</li>
                        <li>Manufactured</li>
                        <li>ResourcesRaw</li>
                        <li>Items</li>
                        <li>Weapons</li>
                        <li>Apparel</li>
                        <li>BodyParts</li>
                    </categories>
                </filter>
            </defaultStorageSettings>
            <ai_chillDestination>false</ai_chillDestination>
            <destroySound>BuildingDestroyed_Metal_Small</destroySound>
        </building>
        <altitudeLayer>Building</altitudeLayer>
        <passability>PassThroughOnly</passability>
        <fillPercent>0.25</fillPercent>
        <pathCost>20</pathCost>
        <surfaceType>None</surfaceType>
        <canOverlapZones>false</canOverlapZones>
        <placeWorkers>
            <li>SK_Matter_Network.PlaceWorker_OneControllerPerNetwork</li>
        </placeWorkers>
        <inspectorTabs>
            <li>SK_Matter_Network.ITab_MatterIOPort</li>
            <li>SK_Matter_Network.ITab_MatterIOPortFilter</li>
            <li>SK_Matter_Network.ITab_NetworkStorage</li>
        </inspectorTabs>
        <researchPrerequisites>
            <li>MN_NetworkIO</li>
        </researchPrerequisites>
        <designationCategory>Misc</designationCategory>
        <defaultPlacingRot>North</defaultPlacingRot>
        <rotatable>false</rotatable>
        <uiIconScale>1</uiIconScale>
        <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
    </ThingDef>

    <ThingDef ParentName="BuildingBase">
        <defName>MN_NetworkPowerStorage</defName>
        <label>network capacitor</label>
        <description>A compact capacitor bank that stores backup power for a connected network. Its stored energy is shared across the network, keeping digitized storage online through brief outages and unstable grids.</description>
        <thingClass>SK_Matter_Network.NetworkBuilding</thingClass>
        <graphicData>
            <texPath>Things/Building/Spaceships/HoloEmitters/BasicHolodeck</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(1,1)</drawSize>
        </graphicData>
        <category>Building</category>
        <comps>
            <li Class="SK_Matter_Network.CompProperties_NetworkBuilding">
                <powerUsage>0</powerUsage>
            </li>
            <li Class="SK_Matter_Network.CompProperties_NetworkPowerStorage">
                <capacity>1000</capacity>
            </li>
        </comps>
        <statBases>
            <MaxHitPoints>150</MaxHitPoints>
            <WorkToBuild>700</WorkToBuild>
            <Mass>5</Mass>
            <Flammability>0.35</Flammability>
            <Beauty>-1</Beauty>
        </statBases>
        <size>(1,1)</size>
        <costList>
            <Steel>100</Steel>
            <ComponentIndustrial>2</ComponentIndustrial>
        </costList>
        <altitudeLayer>BuildingOnTop</altitudeLayer>
        <passability>PassThroughOnly</passability>
        <fillPercent>0.2</fillPercent>
        <pathCost>14</pathCost>
        <building>
            <isInert>true</isInert>
            <destroySound>BuildingDestroyed_Metal_Small</destroySound>
        </building>
        <placeWorkers>
            <li>SK_Matter_Network.PlaceWorker_OneControllerPerNetwork</li>
        </placeWorkers>
        <inspectorTabs>
            <li>SK_Matter_Network.ITab_NetworkStorage</li>
        </inspectorTabs>
        <researchPrerequisites>
            <li>MN_NetworkPowerStorage</li>
        </researchPrerequisites>
        <designationCategory>Misc</designationCategory>
        <defaultPlacingRot>North</defaultPlacingRot>
        <rotatable>false</rotatable>
        <uiIconScale>1</uiIconScale>
        <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
    </ThingDef>

    <ThingDef ParentName="BuildingBase">
        <defName>MN_AdvancedNetworkPowerStorage</defName>
        <label>network reserve cell</label>
        <description>A high-density reserve cell for network infrastructure. It stores a large shared charge for long outages, solar flares, and other disruptions that would otherwise cut access to digitized matter.</description>
        <thingClass>SK_Matter_Network.NetworkBuilding</thingClass>
        <graphicData>
            <texPath>Things/Building/Spaceships/HoloEmitters/HologramRepeater</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(1,1)</drawSize>
        </graphicData>
        <category>Building</category>
        <comps>
